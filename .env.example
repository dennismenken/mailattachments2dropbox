# --- IMAP connection ---
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASSWORD=app-specific-password
IMAP_USE_TLS=true
IMAP_FOLDER=INBOX
IMAP_USE_IDLE=true
IMAP_POLL_INTERVAL_SECONDS=300

# --- Mail lifecycle ---
# What to do with a mail after all its attachments were uploaded successfully.
# keep | move_processed | delete
MAIL_ON_SUCCESS=delete
# What to do with a mail whose sender is not in ALLOWED_SENDERS.
# keep | delete
MAIL_ON_REJECT=delete
# Used only when MAIL_ON_SUCCESS=move_processed
PROCESSED_FOLDER=Processed

# --- Allow lists (CSV, empty value disables the check) ---
# Sender addresses or glob patterns (e.g. *@example.com). Empty = accept all senders.
ALLOWED_SENDERS=
# Allowed attachment extensions (no leading dot). Empty = accept all extensions.
ALLOWED_EXTENSIONS=pdf

# --- Sentinel syntax (search anywhere in the mail body) ---
# Default sentinel looks like: :::in:::paypal
SENTINEL_PREFIX=:::
SENTINEL_SEPARATOR=:::
DEFAULT_BRANCH=in
DEFAULT_SUBFOLDER_KEY=auto

# --- Dropbox (see scripts/setup_dropbox.py for the one-time auth flow) ---
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ROOT_PATH=/Apps/YourAppName/your_workspace

# --- Files ---
MAPPING_FILE=/app/mapping.yaml
LOG_DIR=/app/logs
LOG_LEVEL=INFO

# --- Host UID/GID (Linux only) ---
# The container writes log files into the bind-mounted ./logs directory.
# On Linux this directory must be writable by the UID the container runs as.
# Set PUID/PGID to your host user, e.g. via:
#   echo "PUID=$(id -u)" >> .env
#   echo "PGID=$(id -g)" >> .env
# On macOS Docker Desktop maps UIDs automatically; leave the defaults.
PUID=1000
PGID=1000
